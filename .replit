entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["python313Packages.uvicorn", "yakut"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 80

[userenv]

[userenv.shared]
OPENAI_API_KEY = "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"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dev-server-final-fixed"

[[workflows.workflow]]
name = "dev-server-final-fixed"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m uvicorn main:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
