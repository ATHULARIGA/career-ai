entrypoint = "main.py"

modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "python311", "python311Packages.pip"]

[deployment]
run = ["python3", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "5000"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run App"

[[workflows.workflow]]
name = "Run App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m uvicorn main:app --host 0.0.0.0 --port 8000"
